# Spotify (Client Credentials + OAuth playlist save)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/spotify/callback
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# MusicBrainz — include app name + contact email
MUSICBRAINZ_USER_AGENT=MusicStory/0.1 (your@email.com)

# Last.fm — taste graph & similar-artist discovery (optional)
# App still runs without this; Last.fm enrichment is skipped when unset.
LASTFM_API_KEY=

# Debug
# PLAYLIST_BEYOND_DEBUG=1
# PLAYLIST_VIBE_DEBUG=1
# NEXT_PUBLIC_PLAYLIST_VIBE_DEBUG=1
# NEXT_PUBLIC_DEBUG_RECS=1
# Show curated fallback rabbit holes when real candidates are unavailable (demo only)
# NEXT_PUBLIC_DEMO_FALLBACK=true

# Offline recommendation dev — use fixture worlds instead of live Spotify candidate generation
# NEXT_PUBLIC_USE_RECOMMENDATION_FIXTURES=true

# Persistent recommendation cache directory (Last.fm + Spotify resolutions + playlists)
# CACHE_DIR=./data/cache
